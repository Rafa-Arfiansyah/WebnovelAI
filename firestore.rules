rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the document belongs to the authenticated user
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper to check owner field inside document
    function resourceBelongsToUser() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Helper to check owner field inside request data
    function requestBelongsToUser() {
      return isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Users collection rules
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Projects collection rules
    match /projects/{projectId} {
      allow create: if isAuthenticated() && requestBelongsToUser();
      allow read, update, delete: if isAuthenticated() && resourceBelongsToUser() && requestBelongsToUser();
    }

    // Chapters collection rules
    match /chapters/{chapterId} {
      allow create: if isAuthenticated() && requestBelongsToUser();
      allow read, update, delete: if isAuthenticated() && resourceBelongsToUser() && requestBelongsToUser();
    }

    // Characters collection rules
    match /characters/{characterId} {
      allow create: if isAuthenticated() && requestBelongsToUser();
      allow read, update, delete: if isAuthenticated() && resourceBelongsToUser() && requestBelongsToUser();
    }

    // Locations collection rules
    match /locations/{locationId} {
      allow create: if isAuthenticated() && requestBelongsToUser();
      allow read, update, delete: if isAuthenticated() && resourceBelongsToUser() && requestBelongsToUser();
    }
  }
}
